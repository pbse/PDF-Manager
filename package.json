{
    "name": "pinnacle",
    "version": "1.0.0",
    "description": "Cross-platform PDF management app built with Rust and Tauri",
    "scripts": {
        "tauri": "npx tauri",
        "dev": "npx tauri dev",
        "build": "npx tauri build",
        "build:mac": "npx tauri build",
        "build:win": "npx tauri build --target x86_64-pc-windows-msvc",
        "build:linux": "npx tauri build --target x86_64-unknown-linux-gnu",
        "build:ios": "npx tauri ios build",
        "dev:ios": "npx tauri ios dev",
        "build:android": "npx tauri android build",
        "dev:android": "npx tauri android dev",
        "test:backend": "cargo test --manifest-path src-tauri/Cargo.toml",
        "test:ui": "npm --prefix src/ui run test:ui",
        "test:e2e": "npm --prefix src/ui run test:e2e",
        "test": "npm run test:backend && npm run test:ui && npm run test:e2e",
        "release": "standard-version"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.4.0",
        "standard-version": "^9.5.0"
    },
    "keywords": [
        "tauri",
        "rust",
        "pdf",
        "svelte",
        "cross-platform"
    ],
    "author": "Prashant Bansal",
    "license": "MIT",
    "packageManager": "pnpm@10.6.5+sha512.cdf928fca20832cd59ec53826492b7dc25dc524d4370b6b4adbf65803d32efaa6c1c88147c0ae4e8d579a6c9eec715757b50d4fa35eea179d868eada4ed043af"
}
